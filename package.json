{
  "name": "g-taxwiki",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "comments:fetch": "tsx scripts/fetch-comments.ts",
    "comments:process": "tsx scripts/run-pipeline.ts",
    "comments:dry-run": "tsx scripts/run-pipeline.ts --dry-run",
    "inbox:scan": "tsx scripts/inbox-scanner.ts",
    "orchestrate": "tsx scripts/orchestrator.ts",
    "orchestrate:dry-run": "tsx scripts/orchestrator.ts --dry-run",
    "orchestrate:inbox": "tsx scripts/orchestrator.ts --inbox-only",
    "orchestrate:comments": "tsx scripts/orchestrator.ts --comments-only"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "flexsearch": "^0.8.212",
    "next": "16.2.4",
    "postcss": "^8.5.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/flexsearch": "^0.7.6",
    "@vitejs/plugin-react": "^5.1.2",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^27.4.0",
    "pdf-parse": "^1.1.1",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "vitest": "^4.0.18"
  }
