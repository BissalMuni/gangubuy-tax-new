# =====================================================================
# .env.docker — Docker Claude Dangerous Mode 전용 환경변수 템플릿
# =====================================================================
# 사용법:
#   cp .env.docker.example .env.docker
#   # 그리고 아래 값을 staging/local로 채운다 — 운영(production) 자격증명 절대 금지
#
# 안전 원칙:
#   - .env.docker 는 .gitignore 처리됨 (절대 커밋되지 않음)
#   - docker-compose.claude.yml 의 env_file 을 ".env.docker" 로 지정
#   - 운영 SUPABASE_SERVICE_ROLE_KEY 가 여기 들어가면 AI가 운영 DB 변경 가능 → 금지
# =====================================================================

# ---- Supabase (staging 또는 로컬 supabase CLI) ----
# 옵션 1: Supabase Cloud staging 프로젝트
SUPABASE_URL=https://xxx-staging.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<staging service_role key here>
NEXT_PUBLIC_SUPABASE_URL=https://xxx-staging.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<staging anon key here>

# 옵션 2 (대안): 로컬 Supabase CLI (`supabase start` 실행 후)
# SUPABASE_URL=http://host.docker.internal:54321
# SUPABASE_SERVICE_ROLE_KEY=<로컬 supabase status 출력의 service_role>
# NEXT_PUBLIC_SUPABASE_URL=http://host.docker.internal:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<로컬 supabase status 출력의 anon>

# ---- 003 Phase 1 인증 비번 (테스트용 더미) ----
ADMIN_PASSWORD=test-admin-password
APPROVER_PASSWORD=test-approver-password
EDITOR_PASSWORD=test-editor-password
SESSION_SECRET=test-session-secret-32-bytes-min-here-please

# ---- GitHub (workflow_dispatch 테스트용 — 실제 dispatch 호출 안 할 거면 주석 처리) ----
# GITHUB_TOKEN=ghp_test_token_here
GITHUB_OWNER=BissalMuni
GITHUB_REPO=gangubuy-tax-new

# ---- 인증 페이즈 ----
AUTH_PHASE=1

# ---- 레이트리밋 (선택, Phase 1 신뢰 그룹에서는 미설정 시 graceful degrade) ----
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
