# =============================================================================
# Supabase (server-side only — service_role 키로 DB 직접 조작)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# Phase 2 — Supabase Auth (Magic Link). AUTH_PHASE=2일 때 필수.
# 클라이언트 노출 가능 (anon 키 + URL은 RLS와 함께 안전)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# 인증 페이즈 토글
#   미설정 / 1  → Phase 1 (env 비번 게이트, /admin/login)
#   2          → Phase 2 (Magic Link, /auth/login). 사전에 users 테이블에 admin
#                본인을 insert해두지 않으면 누구도 로그인 불가.
# =============================================================================
AUTH_PHASE=1

# =============================================================================
# Phase 1 비번 게이트 (003 슬라이스 1~2). AUTH_PHASE=1일 때 필수.
# Phase 2로 전환 후에는 ADMIN_PASSWORD만 fallback용으로 유지하거나 삭제.
# =============================================================================
ADMIN_PASSWORD=
APPROVER_PASSWORD=
EDITOR_PASSWORD=
SESSION_SECRET=

# =============================================================================
# 비상 정지 / dispatch (003 슬라이스 9)
# =============================================================================
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# =============================================================================
# Upstash Redis 레이트리밋 (선택 — 미설정 시 인메모리 fallback)
# =============================================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
