# Supabase (댓글·첨부파일) — src/lib/supabase/server.ts
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# JWT 서명 (필수) — src/lib/auth/session.ts, src/middleware.ts
JWT_SECRET=

# 역할별 로그인 비밀번호 (사용할 역할만 채워도 됨)
ROLE_READER_PASSWORD=
ROLE_EDITOR_PASSWORD=
ROLE_SUBADMIN_PASSWORD=
ROLE_ADMIN_PASSWORD=
ROLE_SUPERADMIN_PASSWORD=


# GitHub (관리자 구조 편집 커밋용) — src/lib/admin/github.ts
GITHUB_TOKEN=
GITHUB_REPO=owner/repo